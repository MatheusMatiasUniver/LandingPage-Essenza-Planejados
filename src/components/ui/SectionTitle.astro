---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  label,
  title,
  subtitle,
  align = 'center',
  class: className = '',
} = Astro.props;

const alignClasses = align === 'center' ? 'text-center mx-auto' : 'text-left';
const lineClass = align === 'center' ? 'title-line-center' : 'title-line';
---

<div class:list={['max-w-3xl mb-16', alignClasses, className]}>
  {label && (
    <span class="inline-block text-accent font-medium tracking-widest uppercase text-sm mb-4">
      {label}
    </span>
  )}
  <h2 class:list={['font-heading text-3xl md:text-4xl lg:text-[2.75rem] text-charcoal leading-tight', lineClass]}>
    {title}
  </h2>
  {subtitle && (
    <p class="text-warm-gray text-lg mt-6 leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
